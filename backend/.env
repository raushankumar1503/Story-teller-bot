# ====================================================
# AI Storytelling Bot — Environment Configuration
# ====================================================
# Copy this file to .env and fill in your values

# ------- AI API -------
# Choose ONE of the following:

# Option 1: Groq API (FREE - Recommended)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# ⚠️  REPLACE the value above with your actual Groq key from https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: OpenAI (Paid)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo

# Which provider to use: "groq" or "openai"
AI_PROVIDER=groq

# ------- Server -------
PORT=5000
NODE_ENV=development

# ------- MongoDB -------
# Get free cluster at: https://cloud.mongodb.com
# Leave blank to use in-memory storage (works without MongoDB)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/storyteller

# ------- Session -------
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# ------- CORS -------
# Frontend URL (for deployment)
FRONTEND_URL=http://127.0.0.1:5500
